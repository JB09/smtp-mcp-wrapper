# Copy to `.env` on the host and fill in real values. `.env` is git-ignored and
# must stay that way — it holds the SMTP app password. Nothing secret is baked
# into the image; credentials are injected at runtime.

# --- Image / deploy (read by docker-compose.yml) ---
IMAGE=ghcr.io/your-github-username/smtp-mcp-wrapper:latest
CONTAINER_NAME=email-mcp
# External Docker network shared with your authorization proxy (e.g. Pomerium).
PROXY_NETWORK=pomerium

# --- SMTP relay ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@example.com
# Gmail App Password (Google Account -> Security -> 2-Step Verification -> App passwords).
SMTP_PASS=your-gmail-app-password
MAIL_FROM=you@example.com
MAIL_FROM_NAME=Email MCP

# --- Recipients ---
# Default recipient when `to` is omitted.
DEFAULT_TO=you@example.com
# Comma-separated allowlist. Recipients outside this list are rejected, so even a
# misused tool cannot mail elsewhere. Leave empty to allow any recipient.
ALLOWED_TO=you@example.com

# --- App-layer auth (defense in depth) ---
# The external authorization proxy is ALWAYS required. Set this to `true` to also
# reject /mcp requests that arrive without a Pomerium identity header.
REQUIRE_POMERIUM_IDENTITY=false
# POMERIUM_IDENTITY_HEADER=x-pomerium-assertion

# --- Server bind (rarely changed) ---
# HOST=0.0.0.0
# PORT=8080
